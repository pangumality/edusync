PORT=5000
JWT_SECRET=change-me
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/schoolerp?schema=public

# Required to send contact-message replies from inside the app
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=no-reply@example.com
SMTP_SECURE=false

