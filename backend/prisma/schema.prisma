
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Multi-tenancy model
model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique // For subdomain or header lookup
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
  students  Student[]
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role     @default(STUDENT)
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Student {
  id        String   @id @default(uuid())
  firstName String
  lastName  String
  email     String?
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  SUPER_ADMIN
  ADMIN
  TEACHER
  ACCOUNTANT
  LIBRARIAN
  STUDENT
  PARENT
}
